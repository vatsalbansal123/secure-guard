GEMINI_API_KEY=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_OPENAI_DEPLOYMENT="gpt-5-mini"
# Reasoning models (gpt-5-*) count internal reasoning against the completion
# budget; 2048 is too small for the fix generator (LengthFinishReasonError).
LLM_MAX_TOKENS="8192"
# Reasoning effort for gpt-5-* models: minimal|low|medium|high. Lower = faster
# (less hidden reasoning per call), which matters because the fix node chains
# generate->check per finding. Defaults to "low".
LLM_REASONING_EFFORT="low"

# Database (backend/database/main.py)
DB_SERVER=""
DB_NAME=""
DB_USER=""
DB_PASSWORD=""
